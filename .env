GROQ_API_KEY=#groq_api_key
LLM_PROVIDER=#groq
GROQ_MODEL=#openai/gpt-oss-120b

AAD_AUTH_ENABLED=false
VITE_AAD_ENABLED=false

VITE_AAD_TENANT_ID=<TENANT_ID>
VITE_AAD_CLIENT_ID=<CLIENT_ID>
VITE_AAD_SCOPE=api://<CLIENT_ID>/access_as_user

AAD_TENANT_ID=<TENANT_ID>
AAD_CLIENT_ID=<CLIENT_ID>
# If using Application ID URI:
# AAD_API_AUDIENCE=api://<CLIENT_ID>

SAP_ODATA_BASE_URL=https://<sap-host>/sap/opu/odata/sap
SAP_BP_SERVICE=API_BUSINESS_PARTNER
SAP_BP_ENTITY_SET=A_BusinessPartner
SAP_BP_SELECT=BusinessPartner,BusinessPartnerFullName,BusinessPartnerName,BusinessPartnerCategory,OrganizationBPName1,OrganizationBPName2,FirstName,LastName,Country,Region,Industry

SAP_OAUTH_TOKEN_URL=https://<oauth-host>/oauth2/token
SAP_OAUTH_CLIENT_ID=<SAP_CLIENT_ID>
SAP_OAUTH_CLIENT_SECRET=<SAP_CLIENT_SECRET>
SAP_OAUTH_SCOPE=
SAP_OAUTH_AUDIENCE=
SAP_HTTP_TIMEOUT=20

AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<AZURE_SEARCH_API_KEY>
AZURE_SEARCH_INDEX=<INDEX_NAME>
AZURE_SEARCH_API_VERSION=2023-11-01
AZURE_SEARCH_HTTP_TIMEOUT=15
AZURE_SEARCH_QUERY_TYPE=simple
# optional for vector search
AZURE_SEARCH_VECTOR_PROFILE=
AZURE_SEARCH_VECTOR_FIELD=

DATAVERSE_BASE_URL=https://<org>.crm.dynamics.com
DATAVERSE_API_VERSION=v9.2
DATAVERSE_SUPPLIER_ENTITY_SET=accounts
DATAVERSE_SUPPLIER_SELECT=accountid,name,address1_country,industrycode
DATAVERSE_SUPPLIER_FIELD_ID=accountid
DATAVERSE_SUPPLIER_FIELD_NAME=name
DATAVERSE_SUPPLIER_FIELD_COUNTRY=address1_country
DATAVERSE_SUPPLIER_FIELD_CATEGORY=industrycode
DATAVERSE_HTTP_TIMEOUT=20

DATAVERSE_TENANT_ID=<TENANT_ID>
DATAVERSE_OAUTH_CLIENT_ID=<CLIENT_ID>
DATAVERSE_OAUTH_CLIENT_SECRET=<CLIENT_SECRET>
DATAVERSE_OAUTH_SCOPE=https://<org>.crm.dynamics.com/.default
DATAVERSE_OAUTH_TOKEN_URL=

POWER_AUTOMATE_FLOW_URL=https://<flow-url>
POWER_AUTOMATE_AUTH_TYPE=none
POWER_AUTOMATE_API_KEY=
POWER_AUTOMATE_BEARER_TOKEN=
POWER_AUTOMATE_HTTP_TIMEOUT=15
POWER_AUTOMATE_OAUTH_TOKEN_URL=
POWER_AUTOMATE_OAUTH_CLIENT_ID=
POWER_AUTOMATE_OAUTH_CLIENT_SECRET=
POWER_AUTOMATE_OAUTH_SCOPE=

STORAGE_BACKEND=azure
LOCAL_UPLOADS_DIR=backend/uploads
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
AZURE_BLOB_ACCOUNT_KEY=
AZURE_BLOB_SAS_TOKEN=
AZURE_BLOB_CONTAINER=documents
AZURE_BLOB_CREATE_CONTAINER=true

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<resource>.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=<DOC_INTELLIGENCE_KEY>
AZURE_DOCUMENT_INTELLIGENCE_MODEL=prebuilt-read
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2023-07-31

AZURE_TEXT_ANALYTICS_ENDPOINT=https://<resource>.cognitiveservices.azure.com
AZURE_TEXT_ANALYTICS_API_KEY=<TEXT_ANALYTICS_KEY>
AZURE_TEXT_ANALYTICS_API_VERSION=2023-07-01
AZURE_TEXT_ANALYTICS_LANGUAGE=en
DOC_HTTP_TIMEOUT=30
DOC_TEXT_LIMIT=4000
TEXT_ANALYTICS_MAX_CHARS=5000
